<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_player_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="10dp"
    android:background="@android:color/background_light">

    <ImageView
        android:id="@+id/widget_player_artwork"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginEnd="12dp"
        android:contentDescription="@string/widget_player_artwork_desc"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_launcher_foreground" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_player_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_player_title_default"
            android:textColor="@android:color/black"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_player_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@android:color/darker_gray"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageButton
                    android:id="@+id/widget_player_previous"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/widget_player_previous"
                    android:padding="4dp"
                    android:src="@drawable/widget_skip_previous" />

                <ImageButton
                    android:id="@+id/widget_player_rewind"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="8dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/widget_player_rewind"
                    android:padding="4dp"
                    android:src="@drawable/replay" />

                <ImageButton
                    android:id="@+id/widget_player_toggle"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="4dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/widget_player_play_pause"
                    android:padding="4dp"
                    android:src="@drawable/widget_play_arrow" />

                <ImageButton
                    android:id="@+id/widget_player_fast_forward"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="4dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/widget_player_fast_forward"
                    android:padding="4dp"
                    android:src="@drawable/forward_media" />

                <ImageButton
                    android:id="@+id/widget_player_next"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_marginStart="4dp"
                    android:background="@android:color/transparent"
                    android:contentDescription="@string/widget_player_next"
                    android:padding="4dp"
                    android:src="@drawable/widget_skip_next" />
            </LinearLayout>

            <ImageButton
                android:id="@+id/widget_player_stop"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:background="@android:color/transparent"
                android:contentDescription="@string/widget_player_stop"
                android:padding="4dp"
                android:src="@drawable/stop" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
