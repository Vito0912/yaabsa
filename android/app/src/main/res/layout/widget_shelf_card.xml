<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_shelf_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp"
    android:background="#FF1F2329">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_shelf_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="@string/widget_shelf_title_default"
            android:textColor="#FFF2F3F5"
            android:textSize="14sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/widget_shelf_config"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:background="@android:color/transparent"
            android:contentDescription="@string/widget_shelf_configure"
            android:padding="2dp"
            android:src="@drawable/widget_edit" />
    </LinearLayout>

    <TextView
